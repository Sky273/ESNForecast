generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  consultant
  sales
  administrative
  management
  support
  other
}

enum MissionStatus {
  draft
  planned
  active
  completed
  suspended
  cancelled
}

enum MissionType {
  time_material
  fixed_price
  technical_assistance
  service_center
  other
}

enum ResourceType {
  employee
  partner
  freelancer
}

enum RecurrenceType {
  monthly
  quarterly
  annual
  one_time
}

enum AssignmentCalculationMode {
  business_days
  fixed_days_monthly
  fixed_monthly_amount
}

enum RevenueRecognitionMode {
  billing
  estimated_collection
}

enum UserRole {
  admin
  direction
  finance
  commercial
  readonly
}

enum ScenarioType {
  reference
  pessimistic
  realistic
  optimistic
  custom
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum InvoiceStatus {
  planned
  issued
  paid
  late
  cancelled
}

enum CashStatus {
  planned
  paid
  late
  cancelled
}

enum AlertSeverity {
  info
  warning
  critical
}

enum AlertStatus {
  new
  seen
  resolved
  ignored
}

enum CashInSourceType {
  invoice
  manual
  other
}

enum CashOutSourceType {
  salary
  employer_tax
  freelancer_invoice
  partner_invoice
  fixed_cost
  variable_cost
  tax
  manual
  other
}

model Company {
  id                              String   @id @default(cuid())
  organizationId                  String?
  name                            String
  currency                        String   @default("EUR")
  defaultEmployeeSocialRate       Float    @default(0.22)
  defaultEmployerRate             Float    @default(0.45)
  defaultOverheadRate             Float?
  projectionStartMonth            String
  defaultProjectionHorizonMonths  Int      @default(12)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
  @@index([organizationId])
}

model Employee {
  id                      String         @id @default(cuid())
  firstName               String
  lastName                String
  position                String
  status                  EmployeeStatus
  assignable              Boolean        @default(true)
  startDate               DateTime
  endDate                 DateTime?
  monthlyGrossSalary      Float
  monthlyEmployerCharges  Float?
  employerChargeRate      Float?
  benefitsMonthly         Float          @default(0)
  notes                   String?
  assignments             MissionAssignment[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

model Partner {
  id        String            @id @default(cuid())
  name      String
  notes     String?
  resources PartnerResource[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model PartnerResource {
  id            String              @id @default(cuid())
  partnerId     String
  partner       Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  role          String
  dailyCost     Float
  monthlyFees   Float               @default(0)
  availableFrom DateTime
  availableTo   DateTime?
  notes         String?
  assignments   MissionAssignment[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Freelancer {
  id            String              @id @default(cuid())
  firstName     String
  lastName      String
  specialty     String
  dailyCost     Float
  monthlyFees   Float               @default(0)
  paymentTerms  String?
  availableFrom DateTime
  availableTo   DateTime?
  notes         String?
  assignments   MissionAssignment[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Client {
  id             String    @id @default(cuid())
  name           String
  sector         String
  primaryContact String?
  contactEmail   String?
  paymentDelayDays Int     @default(30)
  notes          String?
  missions       Mission[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Mission {
  id                    String                @id @default(cuid())
  title                 String
  clientId              String
  client                Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status                MissionStatus
  type                  MissionType
  startDate             DateTime
  estimatedEndDate      DateTime?
  actualEndDate         DateTime?
  defaultDailyRate      Float
  fixedPriceAmount      Float?
  signatureProbability  Float                 @default(1)
  paymentDelayDays      Int?
  notes                 String?
  assignments           MissionAssignment[]
  variableCosts         VariableCost[]
  invoiceForecasts      InvoiceForecast[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model MissionAssignment {
  id                    String                    @id @default(cuid())
  missionId             String
  mission               Mission                   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  resourceType          ResourceType
  resourceId            String
  employee              Employee?                 @relation(fields: [employeeId], references: [id])
  employeeId            String?
  partnerResource       PartnerResource?          @relation(fields: [partnerResourceId], references: [id])
  partnerResourceId     String?
  freelancer            Freelancer?               @relation(fields: [freelancerId], references: [id])
  freelancerId          String?
  startDate             DateTime
  estimatedEndDate      DateTime?
  specificDailyRate     Float?
  specificDailyCost     Float?
  occupancyRate         Float
  billedDaysPerMonth    Float?
  calculationMode       AssignmentCalculationMode
  fixedMonthlyAmount    Float?
  notes                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
}

model FixedCost {
  id            String         @id @default(cuid())
  label         String
  category      String
  monthlyAmount Float
  startDate     DateTime
  endDate       DateTime?
  recurrence    RecurrenceType
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model VariableCost {
  id          String          @id @default(cuid())
  label       String
  category    String
  amount      Float
  date        DateTime
  recurrence  RecurrenceType?
  missionId   String?
  mission     Mission?        @relation(fields: [missionId], references: [id], onDelete: SetNull)
  resourceId  String?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectionSettings {
  id                                  String                 @id @default(cuid())
  horizonMonths                       Int                    @default(12)
  averageBusinessDaysPerMonth         Float                  @default(20)
  defaultEmployeeChargeRate           Float                  @default(0.45)
  overheadRate                        Float                  @default(0)
  simplifiedTaxRate                   Float                  @default(0.12)
  revenueRecognitionMode              RevenueRecognitionMode @default(billing)
  defaultPaymentDelayDays             Int                    @default(30)
  defaultSupplierPaymentDelayDays     Int                    @default(30)
  applyProbabilityToPlannedMissions   Boolean                @default(true)
  minimumMarginRate                   Float                  @default(0.2)
  initialCash                         Float                  @default(50000)
  criticalCashThreshold               Float                  @default(15000)
  minimumUtilizationRate              Float                  @default(0.75)
  employeeCostMode                    String                 @default("full_monthly")
  createdAt                           DateTime               @default(now())
  updatedAt                           DateTime               @updatedAt
}

model MonthlyProjectionCache {
  id        String   @id @default(cuid())
  month     String   @unique
  payload   Json
  createdAt DateTime @default(now())
}

model User {
  id           String     @id @default(cuid())
  organizationId String?
  email        String     @unique
  name         String
  role         UserRole   @default(readonly)
  passwordHash String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  @@index([organizationId])
}

model Scenario {
  id               String            @id @default(cuid())
  name             String
  type             ScenarioType
  isActive         Boolean           @default(false)
  riskLevel        RiskLevel         @default(medium)
  author           String?
  notes            String?
  archivedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  invoiceForecasts InvoiceForecast[]
  cashInForecasts  CashInForecast[]
  cashOutForecasts CashOutForecast[]
  simulationEvents SimulationEvent[]
  alerts           Alert[]
}

model ScenarioOverride {
  id         String   @id @default(cuid())
  scenarioId String
  entityType String
  entityId   String
  field      String
  value      Json
  createdAt  DateTime @default(now())
}

model SimulationEvent {
  id               String    @id @default(cuid())
  scenarioId       String
  scenario         Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  type             String
  label            String
  startDate        DateTime
  endDate          DateTime?
  amount           Float?
  percentage       Float?
  relatedMissionId String?
  relatedResourceId String?
  parameters       Json      @default("{}")
  isActive         Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@index([scenarioId])
}

model InvoiceForecast {
  id                  String        @id @default(cuid())
  missionId           String
  mission             Mission       @relation(fields: [missionId], references: [id], onDelete: Cascade)
  scenarioId          String
  scenario            Scenario      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  invoiceDate         DateTime
  dueDate             DateTime
  expectedPaymentDate DateTime
  amountHT            Float
  vatRate             Float?
  amountTTC           Float?
  status              InvoiceStatus @default(planned)
  probability         Float         @default(1)
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  @@index([scenarioId])
  @@index([missionId])
  @@index([invoiceDate])
}

model CashInForecast {
  id             String           @id @default(cuid())
  scenarioId     String
  scenario       Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  sourceType     CashInSourceType
  sourceId       String?
  expectedDate   DateTime
  amount         Float
  probability    Float            @default(1)
  weightedAmount Float
  status         CashStatus       @default(planned)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  @@index([scenarioId])
  @@index([expectedDate])
}

model CashOutForecast {
  id           String            @id @default(cuid())
  scenarioId   String
  scenario     Scenario          @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  sourceType   CashOutSourceType
  sourceId     String?
  expectedDate DateTime
  amount       Float
  status       CashStatus        @default(planned)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  @@index([scenarioId])
  @@index([expectedDate])
}

model Alert {
  id                String        @id @default(cuid())
  scenarioId        String?
  scenario          Scenario?     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  type              String
  severity          AlertSeverity
  message           String
  entityType        String?
  entityId          String?
  month             String?
  recommendedAction String?
  status            AlertStatus   @default(new)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  @@index([scenarioId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
  @@index([entityType, entityId])
}

model ReportExport {
  id        String   @id @default(cuid())
  type      String
  scenarioId String?
  format    String
  payload   Json?
  createdAt DateTime @default(now())
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole @default(readonly)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Timesheet {
  id              String   @id @default(cuid())
  companyId       String?
  resourceType    String
  resourceId      String
  missionId       String
  month           Int
  year            Int
  workedDays      Float
  billableDays    Float
  nonBillableDays Float   @default(0)
  absenceDays     Float   @default(0)
  vacationDays    Float   @default(0)
  sickLeaveDays   Float   @default(0)
  trainingDays    Float   @default(0)
  internalDays    Float   @default(0)
  status          String  @default("draft")
  submittedBy     String?
  approvedBy      String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  lockedAt        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([companyId])
  @@index([missionId])
  @@index([resourceType, resourceId])
  @@index([year, month])
}

model MonthlyActual {
  id                     String   @id @default(cuid())
  companyId              String
  month                  Int
  year                   Int
  actualRevenueGenerated Float    @default(0)
  actualRevenueInvoiced  Float    @default(0)
  actualCashIn           Float    @default(0)
  actualEmployeeCosts    Float    @default(0)
  actualExternalCosts    Float    @default(0)
  actualFixedCosts       Float    @default(0)
  actualVariableCosts    Float    @default(0)
  actualCashOut          Float    @default(0)
  actualGrossMargin      Float    @default(0)
  actualNetMargin        Float    @default(0)
  actualClosingCash      Float    @default(0)
  notes                  String?
  lockedAt               DateTime?
  lockedBy               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  @@unique([companyId, year, month])
  @@index([companyId])
}

model MonthlyClose {
  id                      String   @id @default(cuid())
  companyId               String
  month                   Int
  year                    Int
  status                  String   @default("open")
  initialForecastSnapshot Json?
  revisedForecastSnapshot Json?
  actualSnapshot          Json?
  closedBy                String?
  closedAt                DateTime?
  reopenedBy              String?
  reopenedAt              DateTime?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  @@unique([companyId, year, month])
  @@index([companyId])
}

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  clientId      String
  missionId     String?
  invoiceNumber String   @unique
  invoiceDate   DateTime
  dueDate       DateTime
  amountHT      Float
  vatRate       Float    @default(0.2)
  amountTTC     Float
  status        String   @default("draft")
  paymentDate   DateTime?
  paidAmount    Float    @default(0)
  source        String   @default("manual")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([companyId])
  @@index([clientId])
  @@index([missionId])
  @@index([status])
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  clientId      String
  paymentDate   DateTime
  amount        Float
  paymentMethod String?
  status        String   @default("received")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([invoiceId])
  @@index([clientId])
}

model BillingReconciliation {
  id                String   @id @default(cuid())
  invoiceForecastId String?
  invoiceId         String?
  paymentId         String?
  status            String   @default("unmatched")
  amountVariance    Float    @default(0)
  dateVarianceDays  Int      @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([invoiceForecastId])
  @@index([invoiceId])
}

model CrmOpportunity {
  id                    String   @id @default(cuid())
  externalSource        String
  externalId            String
  clientName            String
  opportunityName       String
  stage                 String
  probability           Float
  expectedAmount        Float
  expectedStartDate     DateTime?
  expectedEndDate       DateTime?
  expectedTJM           Float?
  expectedStaffingNeeds Json?
  owner                 String?
  lastSyncedAt          DateTime?
  rawPayload            Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  @@unique([externalSource, externalId])
}

model AccountingSync {
  id                    String   @id @default(cuid())
  provider              String
  status                String
  lastSyncAt            DateTime?
  importedInvoicesCount Int      @default(0)
  importedPaymentsCount Int      @default(0)
  importedExpensesCount Int      @default(0)
  errors                Json?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model HrSync {
  id                     String   @id @default(cuid())
  provider               String
  status                 String
  lastSyncAt             DateTime?
  importedEmployeesCount Int      @default(0)
  importedAbsencesCount  Int      @default(0)
  errors                 Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Absence {
  id                   String   @id @default(cuid())
  employeeId           String
  startDate            DateTime
  endDate              DateTime
  type                 String
  impactOnBillableDays Float    @default(0)
  source               String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([employeeId])
}

model BusinessCalendar {
  id                 String   @id @default(cuid())
  companyId          String
  country            String
  region             String?
  year               Int
  holidays           Json
  workingDaysByMonth Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@unique([companyId, country, region, year])
}

model Skill {
  id             String   @id @default(cuid())
  name           String
  category       String?
  aliases        Json?
  normalizedName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([normalizedName])
}

model ResourceSkill {
  id              String   @id @default(cuid())
  resourceType    String
  resourceId      String
  skillId         String
  level           String
  yearsExperience Float?
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([resourceType, resourceId])
  @@index([skillId])
}

model MissionSkillNeed {
  id            String   @id @default(cuid())
  missionId     String
  skillId       String
  requiredLevel String
  requiredFTE   Float
  startDate     DateTime
  endDate       DateTime?
  priority      String   @default("medium")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([missionId])
  @@index([skillId])
}

model PlannedHire {
  id                     String   @id @default(cuid())
  scenarioId             String
  title                  String
  targetRole             String
  targetSkills           Json?
  expectedStartDate      DateTime
  expectedMonthlyCost    Float
  expectedEmployerCharges Float   @default(0)
  expectedFullCost       Float
  expectedTJM            Float
  expectedUtilizationRate Float
  onboardingMonths       Int      @default(1)
  probability            Float    @default(1)
  status                 String   @default("planned")
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  @@index([scenarioId])
}

model ProbabilisticAssumption {
  id              String   @id @default(cuid())
  scenarioId      String
  entityType      String
  entityId        String
  field           String
  distributionType String
  minValue        Float
  mostLikelyValue Float
  maxValue        Float
  probability     Float   @default(1)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([scenarioId])
}

model MonteCarloResult {
  id          String   @id @default(cuid())
  scenarioId  String
  iterations  Int
  result      Json
  createdAt   DateTime @default(now())
  @@index([scenarioId])
}

model ApprovalWorkflow {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  status      String   @default("draft")
  requestedBy String?
  approvedBy  String?
  rejectedBy  String?
  requestedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([entityType, entityId])
}

model Notification {
  id                String   @id @default(cuid())
  userId            String?
  type              String
  severity          String
  title             String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  status            String   @default("unread")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([userId])
  @@index([status])
}

model ApiKey {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  keyHash        String
  scopes         Json
  createdAt      DateTime @default(now())
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  @@index([companyId])
}

model WebhookSubscription {
  id                 String   @id @default(cuid())
  companyId          String
  url                String
  events             Json
  secret             String
  isActive           Boolean  @default(true)
  lastDeliveryStatus String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([companyId])
}

model Document {
  id          String   @id @default(cuid())
  companyId   String
  entityType  String
  entityId    String
  fileName    String
  mimeType    String
  size        Int
  storagePath String
  category    String
  uploadedBy  String?
  uploadedAt  DateTime @default(now())
  notes       String?
  @@index([companyId])
  @@index([entityType, entityId])
}

model BusinessRule {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  description String?
  triggerType String
  condition   Json
  action      Json
  severity    String   @default("warning")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([companyId])
}

model Offer {
  id                String   @id @default(cuid())
  clientId          String
  title             String
  status            String   @default("draft")
  expectedStartDate DateTime?
  expectedEndDate   DateTime?
  pricingMode       String
  totalAmount       Float
  expectedMargin    Float
  probability       Float    @default(1)
  notes             String?
  lines             OfferLine[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([clientId])
}

model OfferLine {
  id             String   @id @default(cuid())
  offerId        String
  offer          Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  label          String
  role           String?
  skillNeeds     Json?
  quantity       Float
  durationDays   Float
  tjmSale        Float
  estimatedCost  Float
  expectedMargin Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([offerId])
}

model Connector {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String
  type           String
  provider       String
  name           String
  status         String   @default("inactive")
  configuration  Json?
  lastSyncAt     DateTime?
  nextSyncAt     DateTime?
  errorMessage   String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([organizationId])
  @@index([companyId])
  @@index([type, provider])
  @@index([status])
}

model ConnectorSyncRun {
  id            String   @id @default(cuid())
  connectorId   String
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  status        String
  importedCount Int      @default(0)
  updatedCount  Int      @default(0)
  skippedCount  Int      @default(0)
  errorCount    Int      @default(0)
  errors        Json?
  logs          Json?
  @@index([connectorId])
  @@index([status])
}

model BankConnection {
  id                   String   @id @default(cuid())
  organizationId       String
  companyId            String
  connectorId          String
  provider             String
  externalConnectionId String?
  status               String   @default("pending_consent")
  consentExpiresAt     DateTime?
  lastSyncAt           DateTime?
  createdBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([organizationId])
  @@index([companyId])
  @@index([connectorId])
  @@index([status])
}

model BankConsent {
  id               String   @id @default(cuid())
  organizationId   String
  bankConnectionId String
  provider         String
  status           String
  grantedBy        String?
  grantedAt        DateTime?
  expiresAt        DateTime?
  revokedAt        DateTime?
  scopes           Json
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
